{
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Default": "Host=localhost;Port=5432;Database=blepositioning;Username=postgres;Password=postgres",
    "Redis": "localhost:6379"
  },
  "ApiKey": {
    "Pepper": "dev-pepper-change-in-production"
  },
  "Jwt": {
    "Issuer": "BlePositioning",
    "Audience": "BlePositioning",
    "SigningKey": "CHANGE_ME_MINIMUM_32_CHARACTERS_LONG!!",
    "AccessTokenMinutes": 60
  },
  "DevAdmin": {
    "Username": "admin",
    "Password": "ChangeMe!",
    "Users": [
      { "Username": "admin", "Password": "ChangeMe!", "Role": "Admin" },
      { "Username": "viewer", "Password": "ViewOnly!", "Role": "Viewer" }
    ]
  },
  "FloorMapStorage": {
    "MaxBytes": 6000000,
    "WebRelativeFolder": "maps"
  },
  "Positioning": {
    "DefaultTxPower": -59,
    "PathLossExponent": 2.0,
    "MinBeaconsRequired": 3,
    "RssiAggregationWindowMs": 300,
    "PositionTtlSeconds": 60,
    "UseKalmanFilter": false,
    "StoreKalmanStateInRedis": false,
    "KalmanProcessNoise": 0.05,
    "KalmanMeasurementNoise": 4.0,
    "KalmanStateTtlSeconds": 300
  },
  "DevicePresence": {
    "StateKeyTtl": "7.00:00:00",
    "SweepInterval": "00:00:05",
    "QueryMaxEvents": 10000
  },
  "GeofenceState": {
    "Ttl": "7.00:00:00"
  },
  "RateLimiting": {
    "Enabled": true,
    "RssiPermitLimit": 10,
    "RssiWindowSeconds": 1,
    "GeneralPermitLimit": 60,
    "GeneralWindowMinutes": 1
  },
  "SecurityHeaders": {
    "Enabled": true,
    "UseHsts": false,
    "HstsMaxAgeSeconds": 31536000
  },
  "GeofenceWebhook": {
    "Enabled": false,
    "Url": null,
    "Secret": null,
    "SchemaVersion": "1.0",
    "RequestTimeout": "00:00:08",
    "MaxAttempts": 3,
    "RetryBaseDelay": "00:00:00.400"
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" }
    ],
    "Enrich": [ "FromLogContext" ]
  }
}
