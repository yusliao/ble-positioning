@rendermode InteractiveServer
@using BlePositioning.Application.Security
@inject AdminAuthState Auth
@inject NavigationManager Nav
@inject IOptions<ApiOptions> ApiOptions

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">
            BlePositioning
            @if (!string.IsNullOrEmpty(Auth.BearerToken) && !Auth.IsAdmin)
            {
                <span class="badge text-bg-secondary ms-1">@BlePositioningRoles.Viewer</span>
            }
        </a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="admin-nav-icon" aria-hidden="true">
                    <svg viewBox="0 0 16 16" fill="currentColor"><path d="M6.5 14.5v-3.505c0-.245.25-.495.5-.495h2c.25 0 .5.25.5.5v3.5a.5.5 0 0 0 .5.5h4a.5.5 0 0 0 .5-.5v-7a.5.5 0 0 0-.146-.354L13 5.793V2.5a.5.5 0 0 0-.5-.5h-1a.5.5 0 0 0-.5.5v1.293L8.354 1.146a.5.5 0 0 0-.708 0l-6 6A.5.5 0 0 0 1.5 7.5v7a.5.5 0 0 0 .5.5h4a.5.5 0 0 0 .5-.5z"/></svg>
                </span>
                楼层
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="devices">
                <span class="admin-nav-icon" aria-hidden="true">
                    <svg viewBox="0 0 16 16" fill="currentColor"><path d="M5 0a.5.5 0 0 1 .5.5V2h1V.5a.5.5 0 0 1 1 0V2h1V.5a.5.5 0 0 1 1 0V2A2.5 2.5 0 0 1 14 4.5v7A2.5 2.5 0 0 1 11.5 14h-7A2.5 2.5 0 0 1 2 11.5v-7A2.5 2.5 0 0 1 4.5 2H4V.5a.5.5 0 0 1 .5-.5zM3 4.5A1.5 1.5 0 0 0 4.5 6h7A1.5 1.5 0 0 0 13 4.5v-1A2.5 2.5 0 0 0 10.5 1h-7A2.5 2.5 0 0 0 1 3.5v1A1.5 1.5 0 0 0 3 4.5zm2-1A1.5 1.5 0 0 1 6.5 2h3A1.5 1.5 0 0 1 11 3.5v1A1.5 1.5 0 0 1 9.5 6h-3A1.5 1.5 0 0 1 5 4.5v-1zM2 9v3h12V9H2zm1 1h1v1H3v-1zm2 0h1v1H5v-1zm2 0h1v1H7v-1zm2 0h1v1H9v-1zm2 0h1v1h-1v-1zm2 0h1v1h-1v-1z"/></svg>
                </span>
                设备
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="map-live">
                <span class="admin-nav-icon" aria-hidden="true">
                    <svg viewBox="0 0 16 16" fill="currentColor"><path d="M8 16s6-5.686 6-10A6 6 0 0 0 2 6c0 4.314 6 10 6 10zm0-7a3 3 0 1 1 0-6 3 3 0 0 1 0 6z"/></svg>
                </span>
                实时地图
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="customer-showcase">
                <span class="admin-nav-icon" aria-hidden="true">
                    <svg viewBox="0 0 16 16" fill="currentColor"><path d="M0 4a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2V4zm15 0a1 1 0 0 0-1-1H2a1 1 0 0 0-1 1v8a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1V4z"/><path d="M10.5 8.5a2.5 2.5 0 1 1-5 0 2.5 2.5 0 0 1 5 0z"/></svg>
                </span>
                客户展示
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <a class="nav-link" href="@SwaggerHref" target="_blank" rel="noopener">
                <span class="admin-nav-icon" aria-hidden="true">
                    <svg viewBox="0 0 16 16" fill="currentColor"><path d="M5.854 4.854a.5.5 0 1 0-.708-.708l-3.5 3.5a.5.5 0 0 0 0 .708l3.5 3.5a.5.5 0 0 0 .708-.708L2.707 8l3.147-3.146zm4.292 0a.5.5 0 0 1 .708-.708l3.5 3.5a.5.5 0 0 1 0 .708l-3.5 3.5a.5.5 0 0 1-.708-.708L13.293 8l-3.147-3.146z"/></svg>
                </span>
                Swagger
            </a>
        </div>
        <div class="nav-item px-3">
            @if (string.IsNullOrEmpty(Auth.BearerToken))
            {
                <NavLink class="nav-link" href="login">
                    <span class="admin-nav-icon" aria-hidden="true">
                        <svg viewBox="0 0 16 16" fill="currentColor"><path d="M3 14s-1 0-1-1 1-4 6-4 6 3 6 4-1 1-1 1H3Zm5-6a3 3 0 1 0 0-6 3 3 0 0 0 0 6Z"/></svg>
                    </span>
                    登录
                </NavLink>
            }
            else
            {
                <NavLink class="nav-link" href="@($"/login?returnUrl={Uri.EscapeDataString(Nav.ToBaseRelativePath(Nav.Uri))}")">
                    <span class="admin-nav-icon" aria-hidden="true">
                        <svg viewBox="0 0 16 16" fill="currentColor"><path d="M11 6a3 3 0 1 1-6 0 3 3 0 0 1 6 0z"/><path fill-rule="evenodd" d="M0 8a8 8 0 1 1 16 0A8 8 0 0 1 0 8zm8-7a7 7 0 0 0-6.603 9.329c.18.526.283 1.051.283 1.671 0 .362-.032.714-.093 1.054A7.004 7.004 0 0 0 8 15a7 7 0 0 0 6.603-4.329 7 7 0 0 0-13.206 0A7.004 7.004 0 0 0 8 1z"/></svg>
                    </span>
                    切换账号
                </NavLink>
            }
        </div>
        <div class="nav-item px-3">
            <button type="button" class="nav-link btn btn-link text-start w-100 d-flex align-items-center"
                    @onclick="Logout">
                <span class="admin-nav-icon" aria-hidden="true">
                    <svg viewBox="0 0 16 16" fill="currentColor"><path fill-rule="evenodd" d="M10 12.5a.5.5 0 0 1-.5.5h-8a.5.5 0 0 1-.5-.5v-9a.5.5 0 0 1 .5-.5h8a.5.5 0 0 1 .5.5v2a.5.5 0 0 0 1 0v-2A1.5 1.5 0 0 0 9.5 2h-8A1.5 1.5 0 0 0 0 3.5v9A1.5 1.5 0 0 0 1.5 14h8a1.5 1.5 0 0 0 1.5-1.5v-2a.5.5 0 0 0-1 0v2z"/><path fill-rule="evenodd" d="M15.854 8.354a.5.5 0 0 0 0-.708l-3-3a.5.5 0 0 0-.708.708L14.293 7.5H5.5a.5.5 0 0 0 0 1h8.793l-2.147 2.146a.5.5 0 0 0 .708.708l3-3z"/></svg>
                </span>
                登出
            </button>
        </div>
    </nav>
</div>

@code {
    private string SwaggerHref
    {
        get
        {
            var b = ApiOptions.Value.GetBrowserApiRoot();
            return $"{b}/swagger";
        }
    }

    private void Logout()
    {
        Auth.Clear();
        Nav.NavigateTo("/login");
    }
}
