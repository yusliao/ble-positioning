@rendermode InteractiveServer
@using BlePositioning.Application.Security
@inject AdminAuthState Auth
@inject NavigationManager Nav
@inject IOptions<ApiOptions> ApiOptions

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">
            BlePositioning Admin
            @if (!string.IsNullOrEmpty(Auth.BearerToken) && !Auth.IsAdmin)
            {
                <span class="badge text-bg-secondary ms-1">@BlePositioningRoles.Viewer</span>
            }
        </a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span> 楼层
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="devices">
                <span class="bi bi-cpu-nav-menu" aria-hidden="true"></span> 设备
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="map-live">
                实时地图
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <a class="nav-link" href="@SwaggerHref" target="_blank" rel="noopener">Swagger</a>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="login">
                <span class="bi bi-person-fill-nav-menu" aria-hidden="true"></span> 登录
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <button type="button" class="nav-link btn btn-link text-start p-0"
                    @onclick="Logout">
                登出
            </button>
        </div>
    </nav>
</div>

@code {
    private string SwaggerHref
    {
        get
        {
            var b = ApiOptions.Value.Base?.Trim().TrimEnd('/') ?? "http://localhost:5230";
            return $"{b}/swagger";
        }
    }

    private void Logout()
    {
        Auth.Clear();
        Nav.NavigateTo("/login");
    }
}
