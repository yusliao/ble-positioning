@inherits LayoutComponentBase

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row admin-app-topbar px-4 d-flex align-items-center justify-content-between flex-wrap gap-2">
            <span class="admin-muted-small">BLE 定位管理控制台</span>
            <AdminSessionStatus />
        </div>

        <article class="content admin-content px-4">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>
