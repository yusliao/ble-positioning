@page "/devices/{DeviceId:guid}/trajectory"
@rendermode InteractiveServer
@inject BlePositioningApiClient Api
@inject AdminAuthState Auth
@inject NavigationManager Nav

<PageTitle>设备轨迹</PageTitle>
<p><a href="/devices">返回设备列表</a></p>
<h1>轨迹 <small class="text-muted">@DeviceId</small></h1>
@if (!string.IsNullOrEmpty(_error))
{
    <div class="alert alert-danger" role="alert">@_error</div>
}
<div class="card mb-3">
    <div class="card-body row g-2 align-items-end">
        <div class="col-md-3">
            <label class="form-label">开始 (UTC)</label>
            <input type="datetime-local" class="form-control" @bind="_startLocal" />
        </div>
        <div class="col-md-3">
            <label class="form-label">结束 (UTC)</label>
            <input type="datetime-local" class="form-control" @bind="_endLocal" />
        </div>
        <div class="col-md-2">
            <label class="form-label">间隔 (秒)</label>
            <input type="number" class="form-control" @bind="_interval" min="1" max="60" />
        </div>
        <div class="col-md-2">
            <button type="button" class="btn btn-primary" disabled="@_busy" @onclick="LoadAsync">查询</button>
        </div>
    </div>
</div>
@if (_traj is not null)
{
    <p>共 <strong>@_traj.TotalPoints</strong> 个点。</p>
    @if (_traj.Points.Count > 0)
    {
        <table class="table table-sm table-striped">
            <thead>
            <tr><th>时间 (UTC)</th><th>楼层</th><th>X</th><th>Y</th></tr>
            </thead>
            <tbody>
            @foreach (var p in _traj.Points)
            {
                <tr>
                    <td>@p.Timestamp.ToString("O")</td>
                    <td>@p.FloorId</td>
                    <td>@p.X</td>
                    <td>@p.Y</td>
                </tr>
            }
            </tbody>
        </table>
    }
}

@code {
    [Parameter] public Guid DeviceId { get; set; }

    private DateTime _startLocal;
    private DateTime _endLocal;
    private int _interval = 1;
    private bool _busy;
    private string? _error;
    private DeviceTrajectoryDto? _traj;

    protected override void OnParametersSet()
    {
        var end = DateTime.UtcNow;
        var start = end.AddHours(-1);
        _endLocal = DateTime.SpecifyKind(end, DateTimeKind.Utc);
        _startLocal = DateTime.SpecifyKind(start, DateTimeKind.Utc);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;
        if (string.IsNullOrEmpty(Auth.BearerToken))
        {
            Nav.NavigateTo("/login");
            return;
        }

        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _error = null;
        _busy = true;
        _traj = null;
        await InvokeAsync(StateHasChanged);
        try
        {
            var startUtc = DateTime.SpecifyKind(_startLocal, DateTimeKind.Utc);
            var endUtc = DateTime.SpecifyKind(_endLocal, DateTimeKind.Utc);
            var res = await Api.GetTrajectoryAsync(DeviceId, startUtc, endUtc, _interval);
            if (res?.Success == true && res.Data is not null)
                _traj = res.Data;
            else
                _error = "查询失败或无权限（404 表示设备不存在）。";
        }
        catch (Exception)
        {
            _error = "请求失败。";
        }
        _busy = false;
        await InvokeAsync(StateHasChanged);
    }
}
