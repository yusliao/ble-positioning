@page "/map-live"
@rendermode InteractiveServer
@implements IAsyncDisposable
@inject BlePositioningApiClient Api
@inject AdminAuthState Auth
@inject IOptions<ApiOptions> ApiOptions

<RequireAuth />
<PageTitle>实时地图</PageTitle>
<h1>实时位置</h1>
<p class="text-muted">选择楼层与设备后约每 0.8s 拉取 <code>GET /api/v1/devices/&#123;id&#125;/position</code>。先运行 <code>scripts/demo-simulate-rssi.ps1</code> 或真实 RSSI 上报以产生位姿。地图点叠加假定 <strong>米制与平面图一致</strong>：X 自左向右、<strong>Y 自上向下</strong>（与常见楼层像素坐标系一致）。</p>
@if (!string.IsNullOrEmpty(_error))
{
    <div class="alert alert-danger" role="alert">@_error</div>
}
@if (_loading)
{
    <p>加载中…</p>
}
else
{
    <div class="row g-2 mb-3">
        <div class="col-md-4">
            <label class="form-label">楼层</label>
            <select class="form-select" @bind="_selectedFloorId" @bind:after="OnFloorOrDeviceChanged">
                <option value="">-- 选择 --</option>
                @if (_floors is not null)
                {
                    @foreach (var f in _floors)
                    {
                        <option value="@f.Id">@f.Name</option>
                    }
                }
            </select>
        </div>
        <div class="col-md-4">
            <label class="form-label">设备</label>
            <select class="form-select" @bind="_selectedDeviceId" @bind:after="OnFloorOrDeviceChanged">
                <option value="">-- 选择 --</option>
                @if (_devices is not null)
                {
                    @foreach (var d in _devices)
                    {
                        <option value="@d.Id">@d.DisplayName (@d.DeviceCode)</option>
                    }
                }
            </select>
        </div>
        <div class="col-md-4 d-flex align-items-end">
            <div class="form-check">
                <input class="form-check-input" type="checkbox" id="poll" @bind="_pollingEnabled" @bind:after="OnPollToggle" />
                <label class="form-check-label" for="poll">自动刷新</label>
            </div>
        </div>
    </div>

    @if (_floor is not null)
    {
        <p>楼层尺寸：<strong>@_floor.WidthMeters</strong> m × <strong>@_floor.HeightMeters</strong> m
            @if (string.IsNullOrEmpty(_floor.MapImageUrl))
            {
                <span class="text-warning">（未设置地图，仅显示红点在空白区域）</span>
            }
        </p>
    }

    <div class="map-live__wrap" style="position: relative; display: inline-block; max-width: min(90vw, 900px); border: 1px solid #ccc; background: #f8f9fa;">
        @if (_floor is not null && !string.IsNullOrEmpty(ResolvedMapUrl))
        {
            <img src="@ResolvedMapUrl" alt="map" class="d-block" style="width: 100%; height: auto; vertical-align: top;" />
        }
        else if (_floor is not null)
        {
            <div style="width: 400px; height: 240px; display: flex; align-items: center; justify-content: center; color: #6c757d;">无地图图（可在楼层页上传）</div>
        }
        @if (_position is not null && _floor is not null)
        {
            <div style="@DotStyle" title="@($"X={_position.X:F2} m, Y={_position.Y:F2} m")"></div>
        }
    </div>

    @if (_position is not null)
    {
        <p class="mt-2">X: <strong>@_position.X.ToString("F2")</strong> m, Y: <strong>@_position.Y.ToString("F2")</strong> m · 精度: @_position.Accuracy.ToString("F2") m ·
            @if (_position.IsOnline) { <span class="text-success">在线</span> } else { <span class="text-secondary">离线</span> } ·
            时间(UTC) @_position.Timestamp.ToString("O")
        </p>
    }
    else if (!string.IsNullOrEmpty(_positionHint))
    {
        <p class="mt-2 text-muted">@_positionHint</p>
    }
}

@code {
    private bool _loading = true;
    private string? _error;
    private List<FloorDto>? _floors;
    private List<DeviceSummaryDto>? _devices;
    private FloorDto? _floor;
    private DevicePositionDto? _position;
    private string _positionHint = "请选择楼层与设备并开启自动刷新，或稍候重试。";
    private string? _selectedFloorId;
    private string? _selectedDeviceId;
    private bool _pollingEnabled = true;
    private CancellationTokenSource? _loopCts;

    private string? ResolvedMapUrl
    {
        get
        {
            if (_floor is null || string.IsNullOrWhiteSpace(_floor.MapImageUrl))
                return null;
            var m = _floor.MapImageUrl.Trim();
            if (m.StartsWith("http", StringComparison.OrdinalIgnoreCase))
                return m;
            var b = ApiOptions.Value.GetBrowserApiRoot();
            return m.StartsWith('/') ? $"{b}{m}" : $"{b}/{m}";
        }
    }

    private string DotStyle
    {
        get
        {
            if (_floor is null || _position is null) return "display:none";
            var wM = _floor.WidthMeters;
            var hM = _floor.HeightMeters;
            if (wM <= 0 || hM <= 0) return "display:none";
            // Y: 自楼层图纸顶部向下（与 HTML img 及常见 UI 一致）
            var leftPct = 100.0 * _position.X / wM;
            var topPct = 100.0 * _position.Y / hM;
            return $"position:absolute;left:{leftPct.ToString("F2", System.Globalization.CultureInfo.InvariantCulture)}%;top:{topPct.ToString("F2", System.Globalization.CultureInfo.InvariantCulture)}%;width:14px;height:14px;margin:-7px 0 0 -7px;border-radius:50%;background:var(--map-dot,#c62828);box-shadow:0 0 0 2px var(--map-dot-ring,#fff);pointer-events:none;";
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;
        _loading = true;
        await InvokeAsync(StateHasChanged);
        try
        {
            var fRes = await Api.GetFloorsAsync();
            var dRes = await Api.GetDevicesAsync();
            if (fRes is { Success: true, Data: not null })
                _floors = fRes.Data;
            if (dRes is { Success: true, Data: not null })
                _devices = dRes.Data;
            if (_floors is null || _devices is null)
                _error = "拉取楼层或设备失败。";
        }
        catch
        {
            _error = "加载失败。请检查 API。";
        }
        _loading = false;
        await InvokeAsync(StateHasChanged);
    }

    private async Task OnFloorOrDeviceChanged()
    {
        _position = null;
        _positionHint = "正在拉取…";
        _error = null;
        await ReloadFloorAsync();
        await ApplyPollingAsync();
        await InvokeAsync(StateHasChanged);
    }

    private async Task ReloadFloorAsync()
    {
        _floor = null;
        if (string.IsNullOrEmpty(_selectedFloorId) || !Guid.TryParse(_selectedFloorId, out var fid))
            return;
        var r = await Api.GetFloorByIdAsync(fid);
        if (r is { Success: true, Data: not null })
            _floor = r.Data;
    }

    private Task OnPollToggle() => ApplyPollingAsync();

    private async Task ApplyPollingAsync()
    {
        await StopPollingAsync();
        if (!_pollingEnabled || string.IsNullOrEmpty(_selectedDeviceId) || !Guid.TryParse(_selectedDeviceId, out var did))
        {
            _positionHint = "请开启自动刷新并选择设备。";
            return;
        }

        _loopCts = new CancellationTokenSource();
        var token = _loopCts.Token;
        _ = Task.Run(() => PollingLoopAsync(did, token), CancellationToken.None);
    }

    private async Task PollingLoopAsync(Guid deviceId, CancellationToken token)
    {
        try
        {
            while (!token.IsCancellationRequested)
            {
                try
                {
                    var (ok, data, notFound, err) = await Api.GetDevicePositionAsync(deviceId, token);
                    await InvokeAsync(() =>
                    {
                        if (ok && data is not null)
                        {
                            _position = data;
                            _positionHint = "";
                        }
                        else if (notFound)
                        {
                            _position = null;
                            _positionHint = "尚无位姿或设备不存在。请检查 RSSI 是否已上报。";
                        }
                        else
                        {
                            _position = null;
                            _positionHint = err ?? "查询失败。";
                        }
                        StateHasChanged();
                    });
                }
                catch (OperationCanceledException) when (token.IsCancellationRequested)
                {
                    break;
                }
                try
                {
                    await Task.Delay(800, token);
                }
                catch (OperationCanceledException)
                {
                    break;
                }
            }
        }
        catch (OperationCanceledException) when (token.IsCancellationRequested)
        {
        }
    }

    private async Task StopPollingAsync()
    {
        if (_loopCts is not null)
        {
            try { _loopCts.Cancel(); } catch { /* ignore */ }
            _loopCts.Dispose();
            _loopCts = null;
        }
        await Task.Yield();
    }

    public async ValueTask DisposeAsync() => await StopPollingAsync();
}
