@page "/login"
@rendermode InteractiveServer
@inject BlePositioningApiClient Api
@inject AdminAuthState Auth
@inject NavigationManager Nav
@inject IOptions<ApiOptions> ApiOptions

<PageTitle>登录</PageTitle>
<h1>管理登录</h1>
<p class="text-muted">使用与 API <code>DevAdmin</code> 相同的账号。默认 <strong>admin</strong> / <strong>ChangeMe!</strong>；只读账号示例 <strong>viewer</strong> / <strong>ViewOnly!</strong>（见 API <code>appsettings.json</code> <code>Users</code>）。</p>
<p class="text-muted small">本 Admin 进程访问 API 的基址为：<code>@_apiBaseForHint</code>（<code>appsettings</code> 中 <code>Api:Base</code> 或环境变量 <code>Api__Base</code>）。Docker 管理端对宿主机是 <code>:5001</code>，对 API 多为容器内 <code>http://api:8080</code>。</p>
<EditForm Model="_model" OnValidSubmit="OnSubmitAsync">
    <p>
        <InputText @bind-Value="_model.Username" class="form-control" placeholder="用户名" />
    </p>
    <p>
        <InputText @bind-Value="_model.Password" class="form-control" placeholder="密码" type="password" />
    </p>
    <button class="btn btn-primary" type="submit">登录</button>
    @if (!string.IsNullOrEmpty(_err))
    {
        <p class="text-danger mt-2">@_err</p>
    }
</EditForm>

@code {
    private LoginModel _model = new();
    private string? _err;
    private string _apiBaseForHint => ApiOptions.Value.Base?.Trim() ?? "（未配置）";

    private async Task OnSubmitAsync()
    {
        _err = null;
        var r = await Api.LoginAsync(_model.Username, _model.Password);
        if (!r.Ok || r.Data is null)
        {
            _err = r.ErrorMessage ?? "登录失败，请检查账号、密码与 API 可访问性。";
            return;
        }
        Auth.BearerToken = r.Data.AccessToken;
        Auth.Role = r.Data.Role;
        Nav.NavigateTo("/");
    }

    private sealed class LoginModel
    {
        public string Username { get; set; } = "";
        public string Password { get; set; } = "";
    }
}
